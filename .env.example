# Primary mailbox
MAIL_ADDRESS=default@mail.thm64.com
MAIL_USER=default
MAIL_PASSWORD=smartbox-dev
MAIL_DOMAIN=mail.thm64.com
MAIL_HOSTNAME=mail.thm64.com

# Stalwart recovery/bootstrap admin (used only during first-time setup)
STALWART_ADMIN_PASSWORD=smartbox-admin

# Host ports (plaintext only: SMTP 25, IMAP 1143). Internal network use only.
SMTP_HOST_PORT=25
IMAP_HOST_PORT=1143
STALWART_ADMIN_HOST_PORT=8087
ROUNDCUBE_HOST_PORT=8025

# This machine's LAN IP (used as the host by the helper scripts).
MAIL_SERVER_IP=192.168.1.34

# Outbound SMTP relay / smarthost (all mail to external domains is sent via this
# relay; local-domain mail is still delivered locally). Leave SMTP_RELAY_HOST
# empty to disable relaying and use direct MX delivery.
# Example below is for Cloudflare Email Sending: username is the literal string
# "api_token" and the password is a Cloudflare API token with Email Sending:Edit.
SMTP_RELAY_HOST=
SMTP_RELAY_PORT=465
SMTP_RELAY_IMPLICIT_TLS=true
SMTP_RELAY_USERNAME=api_token
SMTP_RELAY_PASSWORD=
